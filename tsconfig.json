{
  "extends": "@subf/config/tsconfig-lib",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@src": ["./src/index.ts"],
      "@src/*": ["./src/*"]
    },
    "types": ["vite/client", "@testing-library/dom", "node"]
  },
  "include": ["src", "test", "docs"],
  "exclude": ["**/dist", "**/node_modules"]
}
